{
  "name": "@cdcabrera/patternfly-mcp",
  "version": "1.2.0",
  "description": "PatternFly documentation MCP server built with Node.js and TypeScript",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "pf-mcp": "dist/index.js"
  },
  "exports": {
    ".": { "default": "./dist/index.js" },
    "./server": { "types": "./dist/server.d.ts", "default": "./dist/server.js" }
  },
  "files": [
    "dist/**/*",
    "documentation/**/*",
    "README.md",
    "mcp-config-example.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "stop": "node dist/index.js --stop",
    "status": "node dist/index.js --status",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:links": "jest --runTestsByPath tests/docsLinks.test.ts",
    "update-snapshots": "jest -u"
  },
  "keywords": [
    "mcp",
    "server",
    "typescript",
    "nodejs",
    "patternfly",
    "documentation",
    "react"
  ],
  "author": "Jeff Phillips",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.32",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cdcabrera/patternfly-mcp.git"
  },
  "types": "./dist/index.d.ts",
  "bugs": {
    "url": "https://github.com/cdcabrera/patternfly-mcp/issues"
  },
  "homepage": "https://github.com/cdcabrera/patternfly-mcp#readme"
}
